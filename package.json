{
  "name": "aiglossary-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite",
    "dev:worker": "wrangler dev --port 8787",
    "build": "vite build",
    "build:content": "./.venv/bin/python tools/build_published_content.py --glossary-workbook data_glossary.xlsx --structure-workbook data_structure.xlsx --out-dir public/content/published",
    "preview": "vite preview",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "cf:d1:migrate:local": "wrangler d1 migrations apply aiglossary-v2 --local",
    "cf:d1:migrate:remote": "wrangler d1 migrations apply aiglossary-v2 --remote",
    "test": "vitest run",
    "test:python": "./.venv/bin/python -m unittest discover -s tests -p 'test_*.py'",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@clerk/backend": "^3.8.4",
    "@clerk/clerk-react": "^5.61.8",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/spectral": "^5.2.8",
    "@streamdown/cjk": "^1.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dodopayments": "^2.40.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.1",
    "react-router-dom": "^7.18.0",
    "shadcn": "^4.12.0",
    "standardwebhooks": "^1.0.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@react-scan/vite-plugin-react-scan": "^0.2.7",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react-doctor": "^0.7.1",
    "react-scan": "^0.5.7",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
